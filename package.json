{
  "name": "@sunshine-baby/baby-ui",
  "version": "0.0.5",
  "description": "A Vue 3 component library.",
  "type": "module",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style": "./dist/styles/index.css",
    "./*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    }
  },
  "sideEffects": [
    "*.css",
    "*.less",
    "**/style/*"
  ],
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vite build",
    "type-check": "vue-tsc -b --noEmit",
    "sync-publish-version": "node scripts/sync-publish-version.mjs",
    "prepublishOnly": "pnpm sync-publish-version && pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "vue3",
    "components",
    "ui"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "decimal.js": "^10.6.0",
    "lodash": "^4.18.1",
    "vant": "^4.10.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.7",
    "less": "^4.6.7"
  }
}
